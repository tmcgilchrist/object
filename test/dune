 (name test_leb128)
 (libraries object integers alcotest)
 (action
  (run %{exe:test_leb128.exe})))

(test
 (name test_fat)
 (build_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (libraries object integers alcotest)
 (action
  (run %{exe:test_fat.exe})))

(test
 (name test_macho_arm64)
 (deps hello_world)
 (build_if
  (and
   (= %{system} "macosx")
   (= %{architecture} "arm64")))
 (libraries object integers alcotest cmdliner)
 (action
  (run %{exe:test_macho_arm64.exe} --binary %{dep:hello_world})))

